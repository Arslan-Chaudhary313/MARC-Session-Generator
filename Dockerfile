# ہم یہاں مکمل ورژن استعمال کر رہے ہیں جس میں Git موجود ہے
FROM node:20

# ورکنگ ڈائریکٹری سیٹ کریں
WORKDIR /app

# ضروری فائلیں کاپی کریں
COPY package*.json ./

# لائبریریز انسٹال کریں (اب گٹ کا ایرر نہیں آئے گا)
RUN npm install

# باقی تمام کوڈ کاپی کریں
COPY . .

# پورٹ بتائیں
EXPOSE 8000

# بوٹ اسٹارٹ کرنے کی کمانڈ
CMD ["node", "index.js"]
